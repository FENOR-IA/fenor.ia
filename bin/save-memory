#!/bin/bash
# Fenor — save session log for an app
# Usage: save-memory <app-name> [dev|hml|prd]

APP=$1
ENV=${2:-dev}
source /etc/fenor/.env

if [ -z "$APP" ]; then
  echo "  Usage: save-memory <app-name> [dev|hml|prd]"
  exit 1
fi

DATE=$(date +%Y-%m-%d)
LOG_DIR="$APPS_PATH/$ENV/$APP/memory/log"
LOG_FILE="$LOG_DIR/$DATE.md"

mkdir -p "$LOG_DIR"

cat > "$LOG_FILE" <<MD
# $DATE

## What was done


## Decisions made


## Next step


## Open questions

MD

nano "$LOG_FILE"

cd "$APPS_PATH/$ENV/$APP"
git add memory/
git commit -q -m "memory: log $DATE" 2>/dev/null || true
echo "  ✓ Memory saved and versioned."
