#!/bin/bash
# Fenor — promove app DEV → HML → PRD
set -e

APP=$1
source /etc/fenor/.env

if [ -z "$APP" ]; then
  echo "  Uso: fenor promote nome-do-app"
  exit 1
fi

APP_SAFE=$(echo "$APP" | tr '-' '_' | tr '[:upper:]' '[:lower:]')

# Protocolo: http local, https quando Cloudflare configurado
[ -n "$CF_TOKEN" ] && [ -n "$CF_ZONE_ID" ] && PROTO="https" || PROTO="http"

# Detecta ambiente atual e define destino
if [ -d "$APPS_PATH/dev/$APP" ] && [ ! -d "$APPS_PATH/hml/$APP" ]; then
  FROM="dev"; TO="hml"
elif [ -d "$APPS_PATH/hml/$APP" ] && [ ! -d "$APPS_PATH/prd/$APP" ]; then
  FROM="hml"; TO="prd"
elif [ -d "$APPS_PATH/prd/$APP" ]; then
  echo ""
  echo "  $APP já está em produção (PRD)."
  echo "  Para atualizar PRD, use: fenor deploy $APP"
  echo ""
  exit 0
else
  echo "  App '$APP' não encontrado em DEV."
  exit 1
fi

FROM_PATH="$APPS_PATH/$FROM/$APP"
TO_PATH="$APPS_PATH/$TO/$APP"
DB_SCHEMA="${APP_SAFE}_${TO}"
DB_USER="${APP_SAFE}_${TO}_user"
DB_PASS=$(openssl rand -base64 16 | tr -dc 'a-zA-Z0-9' | head -c 20)
SYS_USER="fenor_${APP_SAFE}_${TO}"

echo ""
echo "  Fenor — Promovendo: $APP"
echo "  $FROM → $TO"
echo "  ────────────────────────────────────"

# 1. Copia código + usuário de sistema isolado
mkdir -p "$TO_PATH"
rsync -a --exclude='.env' --exclude='storage/' --exclude='.git/' \
  "$FROM_PATH/" "$TO_PATH/"
id "$SYS_USER" &>/dev/null || useradd -r -M -s /bin/bash -d "$TO_PATH" "$SYS_USER"
usermod -aG www-data "$SYS_USER"
chown -R "$SYS_USER:www-data" "$TO_PATH"
chmod -R 775 "$TO_PATH"
echo "  ✓ Código copiado de $FROM para $TO"
echo "  ✓ Usuário: $SYS_USER"

# 2. Novo schema no banco
sudo -u postgres psql -d fenor <<SQL
CREATE SCHEMA IF NOT EXISTS $DB_SCHEMA;
DO \$\$ BEGIN
  IF NOT EXISTS (SELECT FROM pg_roles WHERE rolname = '$DB_USER') THEN
    CREATE USER $DB_USER WITH PASSWORD '$DB_PASS';
  END IF;
END \$\$;
REVOKE ALL ON SCHEMA public FROM $DB_USER;
GRANT USAGE, CREATE ON SCHEMA $DB_SCHEMA TO $DB_USER;
ALTER USER $DB_USER SET search_path TO $DB_SCHEMA;
ALTER DEFAULT PRIVILEGES IN SCHEMA $DB_SCHEMA GRANT ALL ON TABLES TO $DB_USER;
ALTER DEFAULT PRIVILEGES IN SCHEMA $DB_SCHEMA GRANT ALL ON SEQUENCES TO $DB_USER;
-- fenor_apps_viewer: acesso de integração ao schema promovido
DO \$\$ BEGIN
  IF EXISTS (SELECT FROM pg_roles WHERE rolname = 'fenor_apps_viewer') THEN
    GRANT USAGE ON SCHEMA $DB_SCHEMA TO fenor_apps_viewer;
    ALTER DEFAULT PRIVILEGES IN SCHEMA $DB_SCHEMA GRANT ALL ON TABLES TO fenor_apps_viewer;
    ALTER DEFAULT PRIVILEGES IN SCHEMA $DB_SCHEMA GRANT ALL ON SEQUENCES TO fenor_apps_viewer;
  END IF;
END \$\$;
SQL
echo "  ✓ Banco: schema $DB_SCHEMA (limpo)"

# 3. Terminal isolado para o novo ambiente
for TERM_PORT in $(seq 7700 7999); do
  ss -tlnp | grep -q ":$TERM_PORT " || break
done

if [ "$TO" = "hml" ]; then
  APP_URL="$PROTO://$APP.hml.$BASE_DOMAIN"
  TERM_URL="$PROTO://terminal.$APP.hml.$BASE_DOMAIN"
  TERM_DNS="terminal.$APP.hml"
  NGINX_SERVER="terminal.$APP.hml.$BASE_DOMAIN"
else
  APP_URL="$PROTO://$APP.$BASE_DOMAIN"
  TERM_URL="$PROTO://terminal.$APP.$BASE_DOMAIN"
  TERM_DNS="terminal.$APP"
  NGINX_SERVER="terminal.$APP.$BASE_DOMAIN"
fi

cat > /etc/systemd/system/ttyd-${APP_SAFE}-${TO}.service <<UNIT
[Unit]
Description=ttyd terminal — $APP ($TO)
After=network.target

[Service]
User=$SYS_USER
WorkingDirectory=$TO_PATH
ExecStart=/usr/local/bin/ttyd --port $TERM_PORT --interface 127.0.0.1 --writable bash
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
UNIT

systemctl daemon-reload
systemctl enable ttyd-${APP_SAFE}-${TO} --now &>/dev/null

cat > /etc/nginx/conf.d/terminal-${APP_SAFE}-${TO}.conf <<NGINX
server {
    listen 80;
    server_name $NGINX_SERVER;
    location / {
        proxy_pass http://127.0.0.1:$TERM_PORT;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host \$host;
        proxy_read_timeout 43200s;
    }
}
NGINX
nginx -t && systemctl reload nginx
echo "  ✓ Terminal: $TERM_URL (porta $TERM_PORT)"

# 4. .env do novo ambiente
cat > "$TO_PATH/.env" <<ENV
APP_NAME=$APP
APP_ENV=$TO
APP_URL=$APP_URL
TERMINAL_URL=$TERM_URL
TERMINAL_PORT=$TERM_PORT

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=fenor
DB_SCHEMA=$DB_SCHEMA
DB_USER=$DB_USER
DB_PASS=$DB_PASS
ENV
chown "$SYS_USER:www-data" "$TO_PATH/.env"
chmod 640 "$TO_PATH/.env"
echo "  ✓ .env configurado para $TO"

# 4. Seed data (se existir)
SEED_FILE="$TO_PATH/database/seeds/init.sql"
if [ -f "$SEED_FILE" ]; then
  sudo -u postgres psql -d fenor -c "SET search_path TO $DB_SCHEMA;" -f "$SEED_FILE" &>/dev/null
  echo "  ✓ Seed data aplicada ($SEED_FILE)"
fi

# 5. Git
cd "$TO_PATH"
git config --global --add safe.directory "$TO_PATH" 2>/dev/null || true
git config --global user.email "fenor@fenor.ia" 2>/dev/null || true
git config --global user.name "Fenor" 2>/dev/null || true
git init -q && git checkout -b dev -q 2>/dev/null || true
cat > .gitignore <<GIT
.env
storage/
vendor/
GIT
git add .
git commit -q -m "promote: $APP $FROM → $TO"
echo "  ✓ Git iniciado para $TO"

# 6. DNS — local (/etc/hosts) ou Cloudflare
add_dns() {
  local SUBDOMAIN="$1"
  local FULL="${SUBDOMAIN}.${BASE_DOMAIN}"

  if [ -z "$CF_TOKEN" ] || [ -z "$CF_ZONE_ID" ]; then
    grep -qF "$FULL" /etc/hosts 2>/dev/null || echo "127.0.0.1 $FULL" >> /etc/hosts
    echo "  ✓ DNS local: $FULL"
  else
    CF_RESP=$(curl -s -X POST \
      "https://api.cloudflare.com/client/v4/zones/$CF_ZONE_ID/dns_records" \
      -H "Authorization: Bearer $CF_TOKEN" \
      -H "Content-Type: application/json" \
      --data "{\"type\":\"CNAME\",\"name\":\"${SUBDOMAIN}\",\"content\":\"$CF_TUNNEL_ID.cfargotunnel.com\",\"proxied\":true}")
    echo "$CF_RESP" | grep -q '"success":true' \
      && echo "  ✓ DNS: $FULL" \
      || echo "  ⚠ DNS: crie manualmente $FULL"
  fi
}

if [ "$TO" = "hml" ]; then DNS_APP="$APP.hml"; else DNS_APP="$APP"; fi

add_dns "$DNS_APP"
add_dns "$TERM_DNS"

# Chown final
chown -R "$SYS_USER:www-data" "$TO_PATH"
chmod -R 775 "$TO_PATH"
chmod 640 "$TO_PATH/.env" 2>/dev/null || true

echo ""
echo "  ════════════════════════════════════"
echo "  Promoção concluída!"
echo "  URL:      $APP_URL"
echo "  Terminal: $TERM_URL"
echo "  Banco:    $DB_SCHEMA (novo, limpo)"
echo "  Usuário:  $SYS_USER"
if [ "$TO" = "hml" ]; then
echo "  Status:   pronto para aprovação do cliente"
echo "  Próximo:  fenor promote $APP  (quando aprovado)"
else
echo "  Status:   em produção"
fi
echo "  DEV:      $PROTO://$APP.dev.$BASE_DOMAIN (continua ativo)"
echo "  ════════════════════════════════════"
echo ""
