#!/bin/bash
# Fenor — create new app in DEV
set -e

APP=$1
DESCRIPTION="${2:-}"
TEMPLATE="${3:-base}"
source /etc/fenor/.env

# Read settings from database
GITHUB_TOKEN=$(su - postgres -c "psql -d fenor -t -c \"SELECT value FROM fenor_settings WHERE key='GITHUB_TOKEN'\"" 2>/dev/null | tr -d ' \n')
GITHUB_ORG=$(su - postgres -c "psql -d fenor -t -c \"SELECT value FROM fenor_settings WHERE key='GITHUB_ORG'\"" 2>/dev/null | tr -d ' \n')
ANTHROPIC_API_KEY=$(su - postgres -c "psql -d fenor -t -c \"SELECT value FROM fenor_settings WHERE key='ANTHROPIC_API_KEY'\"" 2>/dev/null | tr -d ' \n')

if [ -z "$APP" ]; then
  echo ""
  echo "  Usage: newapp <app-name> [description] [template]"
  echo ""
  echo "  Examples:"
  echo "    newapp my-crm"
  echo "    newapp my-crm \"Gestão de clientes\" crm"
  echo "    fenor templates list   — ver templates disponíveis"
  echo ""
  exit 1
fi

APP_SAFE=$(echo "$APP" | tr '-' '_' | tr '[:upper:]' '[:lower:]')
TEMPLATE_SAFE=$(echo "$TEMPLATE" | tr -dc 'a-z0-9-')
DB_SCHEMA="${APP_SAFE}_dev"
DB_USER="${APP_SAFE}_dev_user"
DB_PASS=$(openssl rand -base64 16 | tr -dc 'a-zA-Z0-9' | head -c 20)
APP_PATH="$APPS_PATH/dev/$APP"
SYS_USER="fenor_${APP_SAFE}_dev"
APP_ADMIN_PASS=$(openssl rand -base64 12 | tr -dc 'a-zA-Z0-9' | head -c 12)
APP_ADMIN_HASH=$(php -r "echo password_hash('$APP_ADMIN_PASS', PASSWORD_BCRYPT);")

# Protocol: http locally, https when Cloudflare is configured
[ -n "$CF_TOKEN" ] && [ -n "$CF_ZONE_ID" ] && PROTO="https" || PROTO="http"

echo ""
echo "  Fenor — Creating app: $APP"
echo "  ────────────────────────────────────"

# 1. Directory + isolated system user
mkdir -p "$APP_PATH"
rm -f /etc/passwd.lock /etc/shadow.lock /etc/group.lock /etc/gshadow.lock 2>/dev/null || true
id "$SYS_USER" &>/dev/null || useradd -r -M -s /bin/bash -d "$APP_PATH" "$SYS_USER"
usermod -aG www-data "$SYS_USER"
chown -R "$SYS_USER:www-data" "$APP_PATH"
chmod -R 775 "$APP_PATH"
echo "  ✓ Directory: $APP_PATH"
echo "  ✓ System user: $SYS_USER"

# 2. PostgreSQL — isolated schema
su - postgres -c "psql -d fenor" <<SQL
CREATE SCHEMA IF NOT EXISTS $DB_SCHEMA;
DO \$\$ BEGIN
  IF NOT EXISTS (SELECT FROM pg_roles WHERE rolname = '$DB_USER') THEN
    CREATE USER $DB_USER WITH PASSWORD '$DB_PASS';
  END IF;
END \$\$;
REVOKE ALL ON SCHEMA public FROM $DB_USER;
GRANT USAGE, CREATE ON SCHEMA $DB_SCHEMA TO $DB_USER;
ALTER USER $DB_USER SET search_path TO $DB_SCHEMA;
ALTER DEFAULT PRIVILEGES IN SCHEMA $DB_SCHEMA GRANT ALL ON TABLES TO $DB_USER;
ALTER DEFAULT PRIVILEGES IN SCHEMA $DB_SCHEMA GRANT ALL ON SEQUENCES TO $DB_USER;
-- fenor_apps_viewer: read/write access for cross-app integration
DO \$\$ BEGIN
  IF EXISTS (SELECT FROM pg_roles WHERE rolname = 'fenor_apps_viewer') THEN
    GRANT USAGE ON SCHEMA $DB_SCHEMA TO fenor_apps_viewer;
    ALTER DEFAULT PRIVILEGES IN SCHEMA $DB_SCHEMA GRANT ALL ON TABLES TO fenor_apps_viewer;
    ALTER DEFAULT PRIVILEGES IN SCHEMA $DB_SCHEMA GRANT ALL ON SEQUENCES TO fenor_apps_viewer;
  END IF;
END \$\$;
SQL
echo "  ✓ Database: schema $DB_SCHEMA"

# 3. Isolated web terminal per app
for TERM_PORT in $(seq 7700 7999); do
  ss -tlnp | grep -q ":$TERM_PORT " || break
done

# Update /etc/fenor/ttyd.env with the current API key
if [ -n "$ANTHROPIC_API_KEY" ]; then
  echo "ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY" > /etc/fenor/ttyd.env
  chmod 644 /etc/fenor/ttyd.env
fi

cat > /etc/systemd/system/ttyd-${APP_SAFE}-dev.service <<UNIT
[Unit]
Description=ttyd terminal — $APP (dev)
After=network.target

[Service]
User=$SYS_USER
WorkingDirectory=$APP_PATH
Environment=HOME=$APP_PATH
EnvironmentFile=-/etc/fenor/ttyd.env
ExecStart=/usr/local/bin/ttyd --port $TERM_PORT --interface 127.0.0.1 --writable /usr/local/bin/fenor-terminal $APP
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
UNIT

systemctl daemon-reload
systemctl enable ttyd-${APP_SAFE}-dev &>/dev/null
systemctl start ttyd-${APP_SAFE}-dev 2>&1 || warn "ttyd did not start — check: systemctl status ttyd-${APP_SAFE}-dev"

cat > /etc/nginx/conf.d/terminal-${APP_SAFE}-dev.conf <<NGINX
server {
    listen 80;
    server_name terminal.$APP.dev.$BASE_DOMAIN;
    location / {
        proxy_pass http://127.0.0.1:$TERM_PORT;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host \$host;
        proxy_read_timeout 43200s;
    }
}
NGINX
nginx -t && systemctl reload nginx
echo "  ✓ Terminal: $PROTO://terminal.$APP.dev.$BASE_DOMAIN (port $TERM_PORT)"

# 4. App .env
cat > "$APP_PATH/.env" <<ENV
APP_NAME=$APP
APP_ENV=dev
APP_URL=$PROTO://$APP.dev.$BASE_DOMAIN
TERMINAL_URL=$PROTO://terminal.$APP.dev.$BASE_DOMAIN
TERMINAL_PORT=$TERM_PORT

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=fenor
DB_SCHEMA=$DB_SCHEMA
DB_USER=$DB_USER
DB_PASS=$DB_PASS

ADMIN_EMAIL=admin@$APP.local
ADMIN_PASS=$APP_ADMIN_PASS

APP_LANG=$APP_LANG
ENV
chown "$SYS_USER:www-data" "$APP_PATH/.env"
chmod 640 "$APP_PATH/.env"
echo "  ✓ .env configured"

# 5. Copy template
TEMPLATE_DIR="/etc/fenor/templates/$TEMPLATE_SAFE"
if [ -d "$TEMPLATE_DIR" ]; then
  cp -r "$TEMPLATE_DIR/." "$APP_PATH/"
  echo "  ✓ Template: $TEMPLATE_SAFE"
elif [ -d "/etc/fenor/templates/base" ]; then
  cp -r "/etc/fenor/templates/base/." "$APP_PATH/"
  echo "  ✓ Template: base (fallback)"
else
  mkdir -p "$APP_PATH/front" "$APP_PATH/src"
  echo "  ! Template not found — empty scaffold created"
fi

# Initialize database tables
if [ -f "$APP_PATH/database/init.sql" ]; then
  PGPASSWORD="$DB_PASS" psql -h 127.0.0.1 -U "$DB_USER" -d fenor \
    -v ON_ERROR_STOP=1 -f "$APP_PATH/database/init.sql" &>/dev/null || true
  PGPASSWORD="$DB_PASS" psql -h 127.0.0.1 -U "$DB_USER" -d fenor <<SQL 2>/dev/null || true
SET search_path TO $DB_SCHEMA;
INSERT INTO users (name, email, password_hash, role)
VALUES ('Administrator', 'admin@$APP.local', '$APP_ADMIN_HASH', 'admin')
ON CONFLICT (email) DO NOTHING;
SQL
  echo "  ✓ Tables created + initial admin"
fi

# 6. Memory structure + CLAUDE.md
TODAY=$(date '+%Y-%m-%d')
mkdir -p "$APP_PATH/memory/"{progress,context,decisions,log,kb,agents}
mkdir -p "$APP_PATH/.claude/commands"

cat > "$APP_PATH/memory/INDEX.md" <<MD
# $APP — Mapa de Memória

## O que é
${DESCRIPTION:-Descreva o app aqui}

## Status
- Criado: $(date '+%Y-%m-%d %H:%M')
- Ambiente atual: DEV
- URL: $PROTO://$APP.dev.$BASE_DOMAIN
- Banco: $DB_SCHEMA
- Template: $TEMPLATE_SAFE

## Arquivos de memória
- memory/plan.md           → plano atual (escrito no modo Planejador)
- memory/spec.md           → especificação técnica detalhada
- memory/progress/next.md  → próximo passo
- memory/progress/done.md  → o que já foi feito
- memory/progress/blockers.md → o que está travado
- memory/context/produto.md   → o que é o produto, para quem
- memory/context/usuario.md   → perfil do usuário final
- memory/context/negocio.md   → modelo comercial e regras
- memory/kb/domain.md      → regras de negócio específicas
- memory/kb/gotchas.md     → erros e armadilhas descobertas
- memory/kb/integrations.md → APIs e serviços configurados
- memory/log/YYYY-MM-DD.md → diário de cada sessão
- memory/agents/           → relatórios dos agentes autônomos
MD

printf "# Plano\n\nAinda não definido. Use o modo Planejador para criar.\n" \
  > "$APP_PATH/memory/plan.md"
printf "# Especificação Técnica\n\nAinda não definida.\n" \
  > "$APP_PATH/memory/spec.md"
printf "# Próximo passo\n\n" > "$APP_PATH/memory/progress/next.md"
printf "# Feito\n\n"         > "$APP_PATH/memory/progress/done.md"
printf "# Bloqueios\n\n"     > "$APP_PATH/memory/progress/blockers.md"
printf "# Produto\n\n${DESCRIPTION:-}\n" > "$APP_PATH/memory/context/produto.md"
printf "# Usuário final\n\n" > "$APP_PATH/memory/context/usuario.md"
printf "# Negócio\n\n"       > "$APP_PATH/memory/context/negocio.md"
printf "# Regras de negócio\n\n" > "$APP_PATH/memory/kb/domain.md"
printf "# Armadilhas e erros encontrados\n\n" > "$APP_PATH/memory/kb/gotchas.md"
printf "# Integrações configuradas\n\n" > "$APP_PATH/memory/kb/integrations.md"
printf "# $TODAY\n\n## O que foi feito\n\n## Decisões\n\n## Próximo passo\n\n" \
  > "$APP_PATH/memory/log/$TODAY.md"

# .claude/settings.json — hooks de sessão
cat > "$APP_PATH/.claude/settings.json" <<JSON
{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "true" }]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "save-memory $APP_SAFE dev && fenor-save-session $APP_SAFE dev"
          }
        ]
      }
    ]
  }
}
JSON

# Slash commands
cat > "$APP_PATH/.claude/commands/planner.md" <<MD
Você está no **modo Planejador**.

Regras:
- Leia memory/INDEX.md, memory/progress/next.md e memory/context/produto.md
- Analise o código existente sem modificá-lo
- Escreva o plano em memory/plan.md
- Escreva a spec técnica em memory/spec.md
- Atualize memory/progress/next.md com o primeiro passo do plano
- NÃO edite código, NÃO faça commits

Após planejar, informe ao usuário: "Plano salvo em memory/plan.md. Abra o modo Executor para implementar."
MD

cat > "$APP_PATH/.claude/commands/executor.md" <<MD
Você está no **modo Executor**.

**Ao iniciar — faça isso antes de qualquer outra coisa:**
1. Verifique se existe arquivo em memory/sessions/ — se sim, leia o mais recente e apresente um resumo em 3 linhas: o que foi feito, o que está pendente e qual é o próximo passo
2. Leia memory/plan.md — execute exatamente o que está planejado
3. Leia memory/progress/next.md — confirme o passo atual
4. Leia memory/kb/gotchas.md — evite erros já conhecidos

**Durante a execução:**
- Atualize memory/progress/done.md ao concluir cada item
- Atualize memory/progress/next.md ao avançar
- Registre decisões em memory/decisions/$(date '+%Y-%m-%d')-decisao.md

**Ao encerrar (quando o usuário disser que terminou ou pedir para fechar):**
- Execute /save-session para salvar o contexto completo da sessão em memory/sessions/
- Isso garante que a próxima sessão retome exatamente de onde parou
MD

cat > "$APP_PATH/.claude/commands/reviewer.md" <<MD
Você está no **modo Revisor**.

Faça uma revisão completa do código:
1. Segurança — injeção SQL, XSS, CSRF, senhas expostas
2. Performance — queries N+1, índices ausentes, loops desnecessários
3. Qualidade — código duplicado, funções longas, nomenclatura
4. LGPD — dados pessoais sem proteção adequada

Salve o relatório em memory/agents/review-$(date '+%Y-%m-%d').md.
NÃO edite código — apenas documente o que encontrou.
MD

cat > "$APP_PATH/CLAUDE.md" <<MD
# $APP

## Descrição
${DESCRIPTION:-Sem descrição}

## Ambiente
- Env: DEV
- URL: $PROTO://$APP.dev.$BASE_DOMAIN
- Terminal: $PROTO://terminal.$APP.dev.$BASE_DOMAIN
- Banco: schema \`$DB_SCHEMA\` (PostgreSQL)
- Usuário do sistema: \`$SYS_USER\`
- Diretório: $APP_PATH
- Template: $TEMPLATE_SAFE

## Stack
- PHP + Nginx
- PostgreSQL — schema isolado por ambiente
- Cloudflare Tunnel (SSL automático)

## Estrutura
\`\`\`
$APP/
├── front/           → roteador PHP, CSS, JS
├── src/             → Controllers, Auth, Config
├── views/           → views PHP
├── database/        → init.sql (schema do app)
├── memory/          → contexto entre sessões (leia antes de agir)
│   ├── INDEX.md     → mapa geral
│   ├── plan.md      → plano atual
│   ├── progress/    → next / done / blockers
│   ├── context/     → produto / usuário / negócio
│   ├── kb/          → domain / gotchas / integrations
│   ├── log/         → diário de sessões
│   └── agents/      → relatórios dos agentes
├── .claude/
│   ├── settings.json → hooks automáticos
│   └── commands/    → /planner /executor /reviewer
├── CLAUDE.md        → este arquivo
└── .env             → credenciais (nunca commitar)
\`\`\`

## Modos de trabalho

Use os slash commands:
- \`/planner\`  → planeja sem tocar código
- \`/executor\` → executa o plano
- \`/reviewer\` → revisa segurança e qualidade

Comandos ECC disponíveis:
- \`/code-review\`     → revisa o diff atual (bugs, segurança, simplificação)
- \`/security-review\` → auditoria de segurança das mudanças
- \`/checkpoint\`      → salva estado antes de mudanças grandes
- \`/feature-dev\`     → guia estruturado para nova feature

## Regras
- Nunca commitar o .env
- Nunca acessar o schema de outro app
- **Nunca acessar o banco fenor diretamente** — use apenas \`$DB_SCHEMA\`
- Sempre ler memory/plan.md antes de executar
- Registrar decisões importantes em memory/decisions/

## Qualidade de código (PHP)
Seguir as regras ECC para PHP (\`~/.claude/rules/ecc/php/\`):
- PSR-12 e \`declare(strict_types=1)\`
- Prepared statements para todas as queries dinâmicas
- \`password_hash()\` / \`password_verify()\` — nunca MD5/SHA1 para senhas
- Escapar output em templates por padrão
- Não deixar \`var_dump\`, \`dd()\` ou \`die()\` no código
MD
echo "  ✓ Memória, CLAUDE.md e slash commands inicializados"

# 7. SSH Deploy Key (only if GitHub repository is configured)
KEY_DIR="/etc/fenor/keys"
KEY_FILE="$KEY_DIR/${APP_SAFE}"
GITHUB_REPO=$(su - postgres -c "psql -d fenor -t -c \"SELECT github_repo FROM fenor_apps WHERE name='$APP'\"" 2>/dev/null | tr -d ' \n')

if [ -n "$GITHUB_REPO" ]; then
  mkdir -p "$KEY_DIR"
  if [ ! -f "$KEY_FILE" ]; then
    ssh-keygen -t ed25519 -C "fenor-deploy-$APP" -f "$KEY_FILE" -N "" -q
  fi
  chmod 640 "$KEY_FILE" "$KEY_FILE.pub"
  chown root:www-data "$KEY_FILE" "$KEY_FILE.pub"

  # SSH config for the app system user
  mkdir -p "$APP_PATH/.ssh"
  cat > "$APP_PATH/.ssh/config" <<SSH
Host github-$APP
  HostName github.com
  User git
  IdentityFile $KEY_FILE
  IdentitiesOnly yes
  StrictHostKeyChecking no
SSH
  chmod 700 "$APP_PATH/.ssh"
  chmod 600 "$APP_PATH/.ssh/config"
  chown -R "$SYS_USER:www-data" "$APP_PATH/.ssh"

  # SSH config for the fenor admin user
  FENOR_SSH_CONFIG="/home/fenor/.ssh/config"
  mkdir -p /home/fenor/.ssh
  if ! grep -q "Host github-$APP" "$FENOR_SSH_CONFIG" 2>/dev/null; then
    cat >> "$FENOR_SSH_CONFIG" <<SSH

Host github-$APP
  HostName github.com
  User git
  IdentityFile $KEY_FILE
  IdentitiesOnly yes
  StrictHostKeyChecking no
SSH
  fi
  chmod 700 /home/fenor/.ssh
  chmod 600 "$FENOR_SSH_CONFIG" 2>/dev/null || true
  chown -R fenor:fenor /home/fenor/.ssh 2>/dev/null || true

  echo "  ✓ SSH key generated: $KEY_FILE.pub"

  cat >> "$APP_PATH/CLAUDE.md" <<MD

## GitHub
- Repository: $GITHUB_REPO
- Deploy Key: \`$KEY_FILE.pub\`
- To connect: add the public key as a Deploy Key on GitHub (with write access)
MD
fi

# 8. Git — initialize and push initial commit
git config --global --add safe.directory "$APP_PATH" 2>/dev/null || true
git config --global user.email "fenor@fenor.ia" 2>/dev/null || true
git config --global user.name "Fenor" 2>/dev/null || true
cd "$APP_PATH"
git init -q && git checkout -b dev -q 2>/dev/null || true
cat > .gitignore <<GIT
.env
.ssh/
storage/
vendor/
GIT
git add .
git commit -q -m "init: $APP via Fenor"
echo "  ✓ Git initialized (branch dev)"

# Read github_repo and auth method, then configure remote
GITHUB_REPO=$(su - postgres -c "psql -d fenor -t -c \"SELECT github_repo FROM fenor_apps WHERE name='$APP'\"" 2>/dev/null | tr -d ' \n')
GITHUB_AUTH=$(su - postgres -c "psql -d fenor -t -c \"SELECT value FROM fenor_settings WHERE key='GITHUB_AUTH_METHOD'\"" 2>/dev/null | tr -d ' \n')

if [ -n "$GITHUB_REPO" ]; then
  # Normalise to owner/repo (strip host, .git suffix)
  REPO_PATH=$(echo "$GITHUB_REPO" \
    | sed -E 's|.*github[^:]*:([^/]+/[^/]+)(\.git)?$|\1|' \
    | sed -E 's|https?://github\.com/([^/]+/[^/]+)(\.git)?$|\1|' \
    | sed 's|\.git$||')
  # If no slash still (bare name), we can't determine owner — skip remote setup
  if echo "$REPO_PATH" | grep -q '/'; then
    if [ "$GITHUB_AUTH" = "pat" ]; then
      # HTTPS with embedded token — no SSH key needed
      REMOTE_URL="https://${GITHUB_TOKEN}@github.com/${REPO_PATH}.git"
    else
      # SSH alias — requires deploy key to be added on GitHub
      REMOTE_URL="git@github-${APP}:${REPO_PATH}.git"
    fi
    git remote add origin "$REMOTE_URL"
    if [ "$GITHUB_AUTH" = "pat" ]; then
      if git push -u origin dev -q 2>/dev/null; then
        echo "  ✓ Initial push: branch dev → $REPO_PATH"
      else
        echo "  ! Push pending: verify token has repo write access"
      fi
    else
      echo "  ! Push pending: add the deploy key on GitHub and click 'Git push' in Studio"
    fi
  else
    echo "  ! GitHub: could not determine owner — set the full repo in Studio"
  fi
else
  echo "  ! GitHub: set the repository in Studio to enable push"
fi

# 9. DNS — local (/etc/hosts) or Cloudflare
add_dns() {
  local SUBDOMAIN="$1"
  local FULL="${SUBDOMAIN}.${BASE_DOMAIN}"

  if [ -z "$CF_TOKEN" ] || [ -z "$CF_ZONE_ID" ]; then
    grep -qF "$FULL" /etc/hosts 2>/dev/null || echo "127.0.0.1 $FULL" >> /etc/hosts
    echo "  ✓ Local DNS: $FULL"
  else
    CF_RESP=$(curl -s -X POST \
      "https://api.cloudflare.com/client/v4/zones/$CF_ZONE_ID/dns_records" \
      -H "Authorization: Bearer $CF_TOKEN" \
      -H "Content-Type: application/json" \
      --data "{\"type\":\"CNAME\",\"name\":\"${SUBDOMAIN}\",\"content\":\"$CF_TUNNEL_ID.cfargotunnel.com\",\"proxied\":true}")
    echo "$CF_RESP" | grep -q '"success":true' \
      && echo "  ✓ DNS: $FULL" \
      || echo "  ⚠ DNS: create manually $FULL"
  fi
}

add_dns "$APP.dev"
add_dns "terminal.$APP.dev"

# Final permissions
chown -R "$SYS_USER:www-data" "$APP_PATH"
chmod -R 775 "$APP_PATH"
chmod 640 "$APP_PATH/.env" 2>/dev/null || true
echo "  ✓ Permissions set"

echo ""
echo "  ════════════════════════════════════"
echo "  App ready!"
echo "  URL:      $PROTO://$APP.dev.$BASE_DOMAIN"
echo "  Terminal: $PROTO://terminal.$APP.dev.$BASE_DOMAIN"
echo "  Database: $DB_SCHEMA"
echo "  User:     $SYS_USER"
echo ""
echo "  Admin login:"
echo "  Email:    admin@$APP.local"
echo "  Password: $APP_ADMIN_PASS"
echo "  (change the password after first login)"
if [ -n "$GITHUB_REPO" ] && [ -f "$KEY_FILE.pub" ]; then
echo ""
echo "  GitHub — next steps:"
echo "  1. In Studio → Edit app → copy the Deploy Key"
echo "  2. GitHub → repository → Settings → Deploy Keys → Add (write access)"
echo "  3. In Studio → Edit app → click 'Git push' (branch dev)"
echo ""
echo "  Deploy Key: $(cat $KEY_FILE.pub)"
fi
echo "  ════════════════════════════════════"
echo ""
# Open Claude Code only when running in an interactive terminal
if [ -t 0 ]; then
  echo "  Starting Claude Code..."
  cd "$APP_PATH" && exec claude
fi
