#!/bin/bash
# Fenor — carrega credenciais do Claude Code (uso: `source fenor-claude-auth`)
# Usa o token de assinatura (CLAUDE_CODE_OAUTH_TOKEN). Limpa ANTHROPIC_API_KEY
# do ambiente porque a API key sempre tem precedência sobre o token de
# assinatura no `claude` — sem isso, um valor antigo no ambiente quebraria
# o uso da assinatura.

_fenor_claude_setting() {
    local key="$1" val
    val=$(grep -m1 "^${key}=" /etc/fenor/ttyd.env 2>/dev/null | cut -d= -f2-)
    [ -z "$val" ] && val=$(grep -m1 "^${key}=" /etc/fenor/.env 2>/dev/null | cut -d= -f2-)
    printf '%s' "$val"
}

unset ANTHROPIC_API_KEY
CLAUDE_CODE_OAUTH_TOKEN=$(_fenor_claude_setting CLAUDE_CODE_OAUTH_TOKEN)
if [ -n "$CLAUDE_CODE_OAUTH_TOKEN" ]; then
    export CLAUDE_CODE_OAUTH_TOKEN
else
    unset CLAUDE_CODE_OAUTH_TOKEN
fi
unset -f _fenor_claude_setting
