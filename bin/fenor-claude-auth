#!/bin/bash
# Fenor — carrega credenciais do Claude Code (uso: `source fenor-claude-auth`)
# Usa o token de assinatura (CLAUDE_CODE_OAUTH_TOKEN). Limpa ANTHROPIC_API_KEY
# do ambiente porque a API key sempre tem precedência sobre o token de
# assinatura no `claude` — sem isso, um valor antigo no ambiente quebraria
# o uso da assinatura.

_fenor_claude_setting() {
    local key="$1" val
    val=$(grep -m1 "^${key}=" /etc/fenor/ttyd.env 2>/dev/null | cut -d= -f2-)
    [ -z "$val" ] && val=$(grep -m1 "^${key}=" /etc/fenor/.env 2>/dev/null | cut -d= -f2-)
    printf '%s' "$val"
}

unset ANTHROPIC_API_KEY
CLAUDE_CODE_OAUTH_TOKEN=$(_fenor_claude_setting CLAUDE_CODE_OAUTH_TOKEN)
if [ -n "$CLAUDE_CODE_OAUTH_TOKEN" ]; then
    export CLAUDE_CODE_OAUTH_TOKEN
else
    unset CLAUDE_CODE_OAUTH_TOKEN
fi
unset -f _fenor_claude_setting

# O usuário do app não tem permissão de escrita no prefixo global do npm
# (Claude Code instalado como root na imagem) — sem isso, o auto-updater
# mostra "auto-update failed: no write permission to npm prefix, run doctor"
# no início de cada sessão. DISABLE_AUTOUPDATER é a variável de ambiente
# documentada pelo Claude Code para desligar essa checagem; updates passam a
# acontecer só via rebuild da imagem fenor-multi.
export DISABLE_AUTOUPDATER=1

# Com o token de assinatura já no ambiente, pula o wizard de onboarding do
# Claude Code (tema / método de login) na primeira execução de cada perfil —
# sem isso ele pede pra configurar autenticação de novo mesmo com o token
# setado.
if [ -n "$CLAUDE_CODE_OAUTH_TOKEN" ] && command -v node >/dev/null 2>&1 && command -v claude >/dev/null 2>&1; then
    CLAUDE_VERSION=$(claude --version 2>/dev/null | awk '{print $1}') node -e '
        const fs = require("fs");
        const f = process.env.HOME + "/.claude.json";
        const version = process.env.CLAUDE_VERSION;
        let j = {};
        try { j = JSON.parse(fs.readFileSync(f, "utf8")); } catch (e) {}
        let changed = false;
        if (j.hasCompletedOnboarding !== true) { j.hasCompletedOnboarding = true; changed = true; }
        if (version && j.lastOnboardingVersion !== version) { j.lastOnboardingVersion = version; changed = true; }
        if (changed) fs.writeFileSync(f, JSON.stringify(j, null, 2));
    ' 2>/dev/null
fi
