#!/bin/bash
# fenor-terminal — entrypoint do terminal de cada app
# Chamado pelo ttyd no lugar de bash.
# Se /tmp/fenor-session-APP existir, abre no modo definido. Caso contrário, bash normal.

APP=$1
MODE_FILE="/tmp/fenor-flags/session-${APP}"
# Fica numa subpasta sem sticky bit: com fs.protected_regular (padrão no
# Ubuntu), abrir p/ escrita um arquivo de outro dono direto em /tmp (sticky)
# dá EACCES mesmo com 0666. Numa subpasta 0777 sem sticky, o modo do arquivo
# já basta.
SETUP_TOKEN_FLAG="/tmp/fenor-flags/setup-token"

# Carrega credenciais do Claude Code (token de assinatura)
source /usr/local/bin/fenor-claude-auth

# Acionado pelo botão "Gerar token" em Studio > Settings > Claude
if [ -s "$SETUP_TOKEN_FLAG" ]; then
    : > "$SETUP_TOKEN_FLAG" 2>/dev/null  # limpa o conteúdo (arquivo é 0666; evita sticky bit de /tmp no rm)
    unset CLAUDE_CODE_OAUTH_TOKEN
    echo "=================================================="
    echo " Gerando token de assinatura do Claude"
    echo "=================================================="
    echo " 1) Clique no link de autorização que vai aparecer abaixo"
    echo " 2) Faça login com sua conta Claude (Pro ou Max)"
    echo " 3) Volte aqui: vai aparecer um código (sk-ant-oat...)"
    echo " 4) Copie esse código e cole em Studio > Settings > Claude"
    echo "=================================================="
    echo
    claude setup-token
    echo
    echo "=================================================="
    echo " Pronto! Copie o código acima e cole em"
    echo " Studio > Settings > Claude > Token de assinatura"
    echo "=================================================="
fi

if [ -n "$APP" ] && [ -f "$MODE_FILE" ]; then
    APP_SAFE=$(echo "$APP" | tr '-' '_')
    MODE=$(cat "$MODE_FILE" | tr -d '[:space:]')
    rm -f "$MODE_FILE" 2>/dev/null

    _do_save() {
        /usr/local/bin/fenor-save-session "$APP_SAFE" dev 2>/dev/null
    }

    # Salva a cada 5 minutos enquanto a sessão estiver aberta
    ( while sleep 300; do /usr/local/bin/fenor-save-session "$APP_SAFE" dev 2>/dev/null; done ) &
    SAVER_PID=$!

    # Salva ao fechar o browser (SIGHUP) ou matar o processo (SIGTERM)
    trap '_do_save; kill "$SAVER_PID" 2>/dev/null' SIGTERM SIGHUP EXIT

    # Chama fenor-session como subprocesso (sem exec) para manter trap e saver ativos
    /usr/local/bin/fenor-session "$APP" "$MODE"

    # Sessão encerrada normalmente: salva, limpa e sai
    _do_save
    kill "$SAVER_PID" 2>/dev/null
    trap - SIGTERM SIGHUP EXIT
    exit 0
fi

exec bash
