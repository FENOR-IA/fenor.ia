#!/bin/bash
# Fenor — central CLI dispatcher
# Usage: fenor <command> [args]

CMD=$1
shift

case "$CMD" in

  new)
    exec /usr/local/bin/newapp "$@"
    ;;

  promote)
    exec /usr/local/bin/fenor-promote "$@"
    ;;

  status)
    source /etc/fenor/.env
    echo ""
    echo "  Fenor — App Status"
    echo "  ─────────────────────────────────────────────"
    printf "  %-25s %-6s %-30s\n" "APP" "ENV" "URL"
    echo "  ─────────────────────────────────────────────"
    for env in dev hml prd; do
      dir="$APPS_PATH/$env"
      [ -d "$dir" ] || continue
      for app in $(ls "$dir" 2>/dev/null); do
        [ -d "$dir/$app" ] || continue
        envfile="$dir/$app/.env"
        url=""
        [ -f "$envfile" ] && url=$(grep APP_URL "$envfile" | cut -d= -f2)
        printf "  %-25s %-6s %-30s\n" "$app" "$env" "$url"
      done
    done
    echo ""
    ;;

  logs)
    APP=$1
    ENV=${2:-dev}
    source /etc/fenor/.env
    LOG_DIR="$APPS_PATH/$ENV/$APP/storage/logs"
    if [ -d "$LOG_DIR" ]; then
      tail -f "$LOG_DIR"/*.log 2>/dev/null || echo "  No logs found."
    else
      echo "  Log directory not found: $LOG_DIR"
    fi
    ;;

  memory)
    APP=$1
    ENV=${2:-dev}
    source /etc/fenor/.env
    APP_PATH="$APPS_PATH/$ENV/$APP"
    DATE=$(date +%Y-%m-%d)
    LOG_FILE="$APP_PATH/memory/log/$DATE.md"
    mkdir -p "$APP_PATH/memory/log"
    cat > "$LOG_FILE" <<MD
# $DATE

## What was done


## Decisions made


## Next step


## Open questions

MD
    nano "$LOG_FILE"
    cd "$APP_PATH"
    git add memory/
    git commit -q -m "memory: log $DATE" 2>/dev/null || true
    echo "  ✓ Memory saved and versioned."
    ;;

  agent)
    APP=$1; TIPO=$2; ENV=${3:-dev}
    exec /usr/local/bin/fenor-agent "$APP" "$TIPO" "$ENV"
    ;;

  session)
    APP=$1; MODE=${2:-executor}; ENV=${3:-dev}
    exec /usr/local/bin/fenor-session "$APP" "$MODE" "$ENV"
    ;;

  learn)
    APP=$1; ENV=${2:-dev}
    exec /usr/local/bin/fenor-learn "$APP" "$ENV"
    ;;

  update)
    echo ""
    echo "  Atualizando Fenor..."
    curl -fsSL https://fenor.ia.br/update.sh | bash
    ;;

  version|--version|-v)
    echo "  Fenor $(cat /etc/fenor/version 2>/dev/null || echo 'versão desconhecida')"
    ;;

  templates)
    SUBCMD=$1; shift
    TEMPLATES_DIR="/etc/fenor/templates"
    case "$SUBCMD" in
      update)
        if [ ! -d "$TEMPLATES_DIR/.git" ]; then
          echo "  Clonando repositório de templates..."
          git clone --depth=1 https://github.com/FENOR-IA/fenor-ia-template.git "$TEMPLATES_DIR"
        else
          echo "  Atualizando templates..."
          git -C "$TEMPLATES_DIR" pull --ff-only
        fi
        echo "  ✓ Templates atualizados em $TEMPLATES_DIR"
        ;;
      list)
        if [ ! -f "$TEMPLATES_DIR/index.json" ]; then
          echo "  Templates não encontrados. Execute: fenor templates update"
          exit 1
        fi
        echo ""
        echo "  Templates disponíveis:"
        echo "  ─────────────────────────────────────────────"
        python3 -c "
import json, sys
with open('$TEMPLATES_DIR/index.json') as f:
    for t in json.load(f):
        print(f\"  {t['name']:<12} {t.get('label',''):<20} {t.get('description','')}\")
" 2>/dev/null || \
        awk 'BEGIN{RS="{"; FS="\""}
          /\"name\"/ { name=$4 }
          /\"label\"/ { label=$4 }
          /\"description\"/ { print "  " name "\t" label }
        ' "$TEMPLATES_DIR/index.json"
        echo ""
        ;;
      *)
        echo "  Usage: fenor templates <update|list>"
        ;;
    esac
    ;;

  help|--help|-h|"")
    echo ""
    echo "  Fenor — Infrastructure CLI"
    echo ""
    echo "  Commands:"
    echo "    fenor new <app>              Create new app in DEV"
    echo "    fenor promote <app>          Promote DEV→HML or HML→PRD"
    echo "    fenor status                 List all apps and URLs"
    echo "    fenor logs <app> [env]       Tail app logs"
    echo "    fenor memory <app> [env]     Save session log"
    echo "    fenor agent <app> <tipo>     Roda agente autônomo (review|security|performance|suggestions)"
    echo "    fenor session <app> <modo>   Abre Claude Code no modo (planner|executor|reviewer)"
    echo "    fenor learn <app>            Extrai aprendizados da sessão para memória"
    echo "    fenor update                 Atualiza Fenor (scripts + studio + templates)"
    echo "    fenor version                Mostra versão instalada"
    echo "    fenor templates list         Lista templates disponíveis"
    echo "    fenor templates update       Atualiza templates do GitHub"
    echo ""
    echo "  Examples:"
    echo "    fenor new my-crm"
    echo "    fenor promote my-crm"
    echo "    fenor status"
    echo "    fenor templates list"
    echo ""
    ;;

  *)
    echo "  Unknown command: $CMD"
    echo "  Run 'fenor help' for available commands."
    exit 1
    ;;

esac
